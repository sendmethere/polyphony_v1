# Firebase 설정 — 실제 값은 .env 에 넣으세요 (.env 는 git 에서 제외됨).
# Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱(웹) 의 firebaseConfig 값을 복사.
#
# 사용 절차:
#   1) 이 파일을 .env 로 복사:  cp .env.example .env
#   2) 아래 값 채우기
#   3) npm i firebase
#   4) src/lib/store.js 에서 firebaseStore 로 교체 (주석 참고)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MSG_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_REALTIME_DB_URL=
